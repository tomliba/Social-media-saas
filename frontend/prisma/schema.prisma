generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  // Pooled connection (Neon "-pooler" host) — used by the app at runtime
  url       = env("DATABASE_URL")
  // Direct connection (no "-pooler") — used by Prisma Migrate
  directUrl = env("DIRECT_URL")
}

// NextAuth.js models
model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

// User model matching the product spec
model User {
  id            String    @id @default(cuid())
  email         String    @unique
  emailVerified DateTime?
  name          String?
  image         String?
  password      String?   // bcrypt hash; null for Google-only accounts

  // Plan & billing
  plan          String    @default("free") // free, creator, pro
  lemonSqueezyCustomerId String?
  lemonSqueezySubscriptionId String?
  creditBalance Int       @default(0)
  subscriptionStatus String?  // active, past_due, cancelled, expired (from Lemon Squeezy)
  currentPeriodEnd   DateTime? // end of current paid billing period
  customerPortalUrl  String?   // Lemon Squeezy customer portal URL (from subscription webhook urls.customer_portal)

  // Moderation — set to ban; blocks sign-in and invalidates the session (see auth.ts).
  bannedAt      DateTime?

  // User defaults / preferences
  niche         String?
  tone          String    @default("Funny")
  character     String    @default("Doctor")
  defaultVoiceId String?
  background    String    @default("Stock footage")
  duration      String    @default("30s")
  layout        String    @default("Standard")
  language      String    @default("English")

  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  // Relations
  accounts      Account[]
  sessions      Session[]
  contentItems  ContentItem[]
  creditTransactions CreditTransaction[]
  preferences   UserPreferences?
  passwordResetTokens PasswordResetToken[]
}

model PasswordResetToken {
  id         String    @id @default(cuid())
  userId     String
  tokenHash  String    @unique
  expires    DateTime
  consumedAt DateTime?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

// Per-format default settings that pre-fill the Create flow.
// Every field is nullable: null means "no preference" — the Create flow keeps
// its current hardcoded default. Tone is stored per-format-context because the
// Character flow uses an 11-tone set while AI Story / Argument / Skeleton share
// a different 12-tone set (never merged).
model UserPreferences {
  id     String @id @default(cuid())
  userId String @unique
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  // ── Global look (applies to every format) ──
  captionStyle     String?
  captionFontSize  String?  // small | medium | large
  captionTransform String?  // normal | uppercase | capitalize | lowercase
  captionPosition  String?  // top | middle | bottom
  music            String?  // track id | "none" (explicit no music) | null (no override)
  filmGrain        Boolean?
  shakeEffect      Boolean?
  language         String?  // not applied to Argument (no language there)

  // ── Character video ──
  characterNiche          String?
  characterName           String?
  characterVoiceId        String?
  characterSpeed          Float?
  characterBackgroundMode String?
  characterArtStyle       String?
  characterTone           String?  // Character 11-tone set
  characterDuration       String?  // "15s" | "30s" | "60s" | "90s"

  // ── AI voice story ──
  storyTopicPreset String?
  storyArtStyle    String?
  storySceneMode   String?  // static | animated
  storyTone        String?  // 12-tone set
  storyVoiceId     String?
  storyDuration    Int?     // 30 | 60 | 90 | 120

  // ── Argument video ──
  argumentCharacterA  String?
  argumentCharacterB  String?
  argumentTone        String?  // 12-tone set
  argumentDuration    Int?     // 30 | 45 | 60 | 90

  // ── Skeleton video ──
  skeletonColor    String?  // cool | warm | red
  skeletonVoiceId  String?
  skeletonTone     String?  // 12-tone set
  skeletonDuration Int?     // 30 | 60 | 90 | 120

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// Append-only credit ledger. Balance is mirrored on User.creditBalance;
// every change to that balance MUST go through one of these rows.
model CreditTransaction {
  id              String   @id @default(cuid())
  userId          String
  user            User     @relation(fields: [userId], references: [id])
  delta           Int      // signed: negative = spend, positive = grant/refund
  balanceAfter    Int
  type            String   // signup_grant, subscription_grant, topup, render_spend, post_spend, refund, adjustment
  reason          String?
  jobId           String?  // ContentItem.jobId / Trigger run id for charge↔refund pairing
  externalEventId String?  // Lemon Squeezy webhook event id for grant idempotency
  createdAt       DateTime @default(now())

  @@index([userId])
  @@unique([jobId, type])        // idempotency: one charge + one refund per job
  @@unique([externalEventId])    // idempotency: one grant per webhook event
}

// Append-only log of every Lemon Squeezy webhook delivery (written after the
// signature check, including unknown-user and unhandled events). This is what
// makes "paid but no credits" detectable: a subscription_payment_success /
// order_created row with no grantedCreditTxId is a billing-health alert.
// Only covers events received after this table was deployed.
model WebhookEvent {
  id                String   @id @default(cuid())
  eventName         String
  resourceId        String?  // LS resource id (data.id)
  userId            String?  // resolved app user, when known
  rawPayload        Json     // parsed payload ({} when unparseable / bad signature)
  signatureValid    Boolean
  handled           Boolean  @default(false) // true once a known case ran without error
  grantedCreditTxId String?  // CreditTransaction.id when this event granted credits
  error             String?
  createdAt         DateTime @default(now())

  @@index([eventName])
  @@index([createdAt])
}

model ContentItem {
  id              String   @id @default(cuid())
  userId          String
  jobId           String   @unique // Trigger.dev run ID or direct-* for local dev
  title           String
  format          String   // video, carousel, image, text
  templateId      String?
  backgroundMode  String?
  status          String   @default("rendering") // rendering, ready, failed
  videoUrl        String?
  thumbnailUrl    String?
  script          String?
  durationSec     Int?
  renderTimeSec   Int?
  error           String?
  previewData     String?  // JSON: audioUrl, backgroundPaths, captions, volumePerFrame, durationInFrames, fps, backgroundType, showCaptions
  creativeSettings String? // JSON: captionStyle, music, musicUrl, filmGrain, shakeEffect, transitionStyle, hookText, etc.
  resolvedSegments String? // JSON: resolved visual segments for render-export

  // Observability only (NOT part of credit charging/refund). Measured USD
  // provider cost for this render, reported by the backend at completion.
  // null = not captured (old renders / backend not yet instrumented) → the
  // admin dashboard falls back to the credit-rate estimate for those.
  providerCostUsd Float?
  costBreakdown   Json?    // { flux:{model,images,usd}, seedance:{seconds,usd}, tts:{chars,usd}, llm:{inTok,outTok,usd}, transcribe:{minutes,model,usd}, estimated?:bool }

  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  user            User     @relation(fields: [userId], references: [id])

  @@index([userId, status])
  @@index([userId, createdAt])
}

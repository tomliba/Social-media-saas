generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

// NextAuth.js models
model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

// User model matching the product spec
model User {
  id            String    @id @default(cuid())
  email         String    @unique
  emailVerified DateTime?
  name          String?
  image         String?

  // Plan & billing
  plan          String    @default("free") // free, starter, creator, pro
  lemonSqueezyCustomerId String?
  lemonSqueezySubscriptionId String?

  // User defaults / preferences
  niche         String?
  tone          String    @default("Funny")
  character     String    @default("Doctor")
  defaultVoiceId String?
  background    String    @default("Stock footage")
  duration      String    @default("30s")
  layout        String    @default("Standard")
  language      String    @default("English")

  // Usage counters (reset monthly)
  videosUsed    Int       @default(0)
  videosLimit   Int       @default(3)
  postsUsed     Int       @default(0)
  postsLimit    Int       @default(10)
  usageResetAt  DateTime  @default(now())

  // Autopilot settings
  autopilotEnabled Boolean @default(false)

  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  // Relations
  accounts      Account[]
  sessions      Session[]
  contentItems  ContentItem[]
}

model ContentItem {
  id              String   @id @default(cuid())
  userId          String
  jobId           String   @unique // Trigger.dev run ID or direct-* for local dev
  title           String
  format          String   // video, carousel, image, text
  templateId      String?
  backgroundMode  String?
  status          String   @default("rendering") // rendering, ready, failed
  videoUrl        String?
  thumbnailUrl    String?
  script          String?
  durationSec     Int?
  renderTimeSec   Int?
  error           String?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  user            User     @relation(fields: [userId], references: [id])

  @@index([userId, status])
  @@index([userId, createdAt])
}

# ── Database (Neon Postgres) ──
# DATABASE_URL = POOLED connection (host contains "-pooler") — used by the app at runtime
# DIRECT_URL   = DIRECT connection (host WITHOUT "-pooler") — used by Prisma Migrate
# Copy both from the Neon dashboard. Keep ?sslmode=require on each.
DATABASE_URL="postgresql://USER:PASSWORD@ep-xxxx-pooler.REGION.aws.neon.tech/DBNAME?sslmode=require"
DIRECT_URL="postgresql://USER:PASSWORD@ep-xxxx.REGION.aws.neon.tech/DBNAME?sslmode=require"

# ── NextAuth ──
AUTH_SECRET="generate-a-real-secret-for-production"
AUTH_URL="http://localhost:3000"

# Google OAuth
AUTH_GOOGLE_ID="your-google-client-id"
AUTH_GOOGLE_SECRET="your-google-client-secret"

# ── Gemini ──
GEMINI_API_KEY=""

# ── OpenAI ──
OPENAI_API_KEY=""

# ── Flask video backend (local dev → http://localhost:5000, production → hosted URL) ──
FLASK_API_URL=""
FLASK_API_KEY=""

# ── Cloudflare R2 (optional — falls back to local public/uploads/ storage) ──
R2_ACCOUNT_ID=""
R2_ACCESS_KEY_ID=""
R2_SECRET_ACCESS_KEY=""
R2_BUCKET_NAME="content-library"
R2_PUBLIC_URL=""

# ── Trigger.dev — https://cloud.trigger.dev ──
# Comment out TRIGGER_SECRET_KEY to use direct Flask calls (no Trigger.dev needed)
TRIGGER_SECRET_KEY=""
TRIGGER_PROJECT_REF=""

# ── Credit billing ──
# Shared secret protecting the render-completion callback
# (/api/library/[id]/complete). Generate with:
#   node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
# IMPORTANT: set the SAME value in the Trigger.dev project env so tasks can send it.
TRIGGER_CALLBACK_SECRET=""

# Secret for the reconciliation cron route. Cron must send:
#   Authorization: Bearer <CRON_SECRET>
CRON_SECRET=""

# Lemon Squeezy webhook signing secret (LS Dashboard → Settings → Webhooks).
LEMONSQUEEZY_WEBHOOK_SECRET=""
# Lemon Squeezy store subdomain (<slug>.lemonsqueezy.com) for hosted checkout
# links. Defaults to "doctorcurses" in code; override here per environment.
LEMONSQUEEZY_STORE="doctorcurses"

# Public app URL used by Trigger.dev tasks to call back into this app.
# (Set in the Trigger.dev project env for production.)
NEXT_PUBLIC_APP_URL="http://localhost:3000"

# Email/password auth (Phase 1)
RESEND_API_KEY=""                       # Resend API key for verification/reset emails
EMAIL_FROM="The Fluid Curator <noreply@yourdomain.com>"
ADMIN_EMAILS=""                         # comma-separated admin emails (granted role "admin")
UPSTASH_REDIS_REST_URL=""               # Upstash Redis for login/reset rate limiting
UPSTASH_REDIS_REST_TOKEN=""

# Cloudflare Turnstile (invisible captcha)
NEXT_PUBLIC_TURNSTILE_SITE_KEY=
TURNSTILE_SECRET_KEY=

# ipinfo Lite (free, commercial-OK) — optional; enables ASN/datacenter flags
IPINFO_TOKEN=

# Signup-abuse hardening kill-switch. Unset/anything = ON (captcha + disposable
# + Google OAuth gate enforced). Set to "false"/"0"/"off"/"no" to bypass the
# gates (emergency rollback). The emailVerified credit-grant gate is always on.
SIGNUP_HARDENING_ENABLED=
